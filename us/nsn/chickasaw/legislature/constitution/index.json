{"t": "Constitution of the Chickasaw Nation", "p": "/us/nsn/chickasaw/legislature/constitution", "et": "document", "sc": "Chickasaw Constitution", "rd": "Chickasaw Nation Constitution", "ei": "us/nsn/chickasaw/legislature/docs/constitution", "sp": "library|Chickasaw Nation Constitution", "sd": true, "xp": "/us/nsn/chickasaw/legislature/constitution/index.xml", "c": [{"t": "PREAMBLE", "p": "/us/nsn/chickasaw/legislature/constitution#preamble", "et": "container", "sc": " PREAMBLE", "rp": "PREAMBLE", "sp": "library|Chickasaw Nation Constitution|"}, {"t": "ARTICLE I NAME", "p": "/us/nsn/chickasaw/legislature/constitution#I", "et": "container", "sc": " ARTICLE I", "rp": "I", "sp": "library|Chickasaw Nation Constitution|I"}, {"t": "ARTICLE II CITIZENSHIP", "p": "/us/nsn/chickasaw/legislature/constitution#II", "et": "container", "sc": " ARTICLE II", "rp": "II", "sp": "library|Chickasaw Nation Constitution|II", "c": [{"t": "1", "p": "/us/nsn/chickasaw/legislature/constitution#II/1", "et": "section", "sc": " ARTICLE II, 1", "rp": "II|\u00a71", "sp": "library|Chickasaw Nation Constitution|II|1", "x": "This Chickasaw Nation shall consist of all Chickasaw Indians by blood whose"}, {"t": "2", "p": "/us/nsn/chickasaw/legislature/constitution#II/2", "et": "section", "sc": " ARTICLE II, 2", "rp": "II|\u00a72", "sp": "library|Chickasaw Nation Constitution|II|2", "x": "The Tribal Legislature shall have the power to enact ordinances governing f"}]}, {"t": "ARTICLE III RIGHTS OF SUFFRAGE", "p": "/us/nsn/chickasaw/legislature/constitution#III", "et": "container", "sc": " ARTICLE III", "rp": "III", "sp": "library|Chickasaw Nation Constitution|III", "c": [{"t": "1", "p": "/us/nsn/chickasaw/legislature/constitution#III/1", "et": "section", "sc": " ARTICLE III, 1", "rp": "III|\u00a71", "sp": "library|Chickasaw Nation Constitution|III|1", "x": "All citizens eighteen (18) years of age or older shall be deemed qualified "}, {"t": "2", "p": "/us/nsn/chickasaw/legislature/constitution#III/2", "et": "section", "sc": " ARTICLE III, 2", "rp": "III|\u00a72", "sp": "library|Chickasaw Nation Constitution|III|2", "x": "No enrolled member of another tribe or person who votes as a citizen or mem"}]}, {"t": "ARTICLE IV BILL OF RIGHTS", "p": "/us/nsn/chickasaw/legislature/constitution#IV", "et": "container", "sc": " ARTICLE IV", "rp": "IV", "sp": "library|Chickasaw Nation Constitution|IV", "c": [{"t": "1", "p": "/us/nsn/chickasaw/legislature/constitution#IV/1", "et": "section", "sc": " ARTICLE IV, 1", "rp": "IV|\u00a71", "sp": "library|Chickasaw Nation Constitution|IV|1", "x": "Nothing in this Constitution shall be interpreted in a way which would chan"}, {"t": "2", "p": "/us/nsn/chickasaw/legislature/constitution#IV/2", "et": "section", "sc": " ARTICLE IV, 2", "rp": "IV|\u00a72", "sp": "library|Chickasaw Nation Constitution|IV|2", "x": "All political power is inherent in the people, and all free governments are"}, {"t": "3", "p": "/us/nsn/chickasaw/legislature/constitution#IV/3", "et": "section", "sc": " ARTICLE IV, 3", "rp": "IV|\u00a73", "sp": "library|Chickasaw Nation Constitution|IV|3", "x": "No religious test shall ever be required as a qualification for any office "}, {"t": "4", "p": "/us/nsn/chickasaw/legislature/constitution#IV/4", "et": "section", "sc": " ARTICLE IV, 4", "rp": "IV|\u00a74", "sp": "library|Chickasaw Nation Constitution|IV|4", "x": "Every citizen shall be at liberty to speak, write, or publish his opinions "}, {"t": "5", "p": "/us/nsn/chickasaw/legislature/constitution#IV/5", "et": "section", "sc": " ARTICLE IV, 5", "rp": "IV|\u00a75", "sp": "library|Chickasaw Nation Constitution|IV|5", "x": "The citizens shall have the right, in a peaceable manner, to assemble toget"}]}, {"t": "ARTICLE V DIVISION OF THE POWERS OF GOVERNMENT", "p": "/us/nsn/chickasaw/legislature/constitution#V", "et": "container", "sc": " ARTICLE V", "rp": "V", "sp": "library|Chickasaw Nation Constitution|V", "c": [{"t": "1", "p": "/us/nsn/chickasaw/legislature/constitution#V/1", "et": "section", "sc": " ARTICLE V, 1", "rp": "V|\u00a71", "sp": "library|Chickasaw Nation Constitution|V|1", "x": "The powers of the government of the Chickasaw Nation shall be divided into "}, {"t": "2", "p": "/us/nsn/chickasaw/legislature/constitution#V/2", "et": "section", "sc": " ARTICLE V, 2", "rp": "V|\u00a72", "sp": "library|Chickasaw Nation Constitution|V|2", "x": "The officers of the Nation are to include all elective officials."}]}, {"t": "ARTICLE VI LEGISLATIVE DEPARTMENT", "p": "/us/nsn/chickasaw/legislature/constitution#VI", "et": "container", "sc": " ARTICLE VI", "rp": "VI", "sp": "library|Chickasaw Nation Constitution|VI", "c": [{"t": "1", "p": "/us/nsn/chickasaw/legislature/constitution#VI/1", "et": "section", "sc": " ARTICLE VI, 1", "rp": "VI|\u00a71", "sp": "library|Chickasaw Nation Constitution|VI|1", "x": "The Legislative authority of the Chickasaw Nation shall be vested in the Tr"}, {"t": "2", "p": "/us/nsn/chickasaw/legislature/constitution#VI/2", "et": "section", "sc": " ARTICLE VI, 2", "rp": "VI|\u00a72", "sp": "library|Chickasaw Nation Constitution|VI|2", "x": "Members of the Tribal Legislature must be citizens of the Nation and have b"}, {"t": "3", "p": "/us/nsn/chickasaw/legislature/constitution#VI/3", "et": "section", "sc": " ARTICLE VI, 3", "rp": "VI|\u00a73", "sp": "library|Chickasaw Nation Constitution|VI|3", "x": "The Tribal Legislature shall consist of thirteen (13) members to be elected"}, {"t": "4", "p": "/us/nsn/chickasaw/legislature/constitution#VI/4", "et": "section", "sc": " ARTICLE VI, 4", "rp": "VI|\u00a74", "sp": "library|Chickasaw Nation Constitution|VI|4", "x": "For the first election under this Constitution, the thirteen (13) positions"}, {"t": "5", "p": "/us/nsn/chickasaw/legislature/constitution#VI/5", "et": "section", "sc": " ARTICLE VI, 5", "rp": "VI|\u00a75", "sp": "library|Chickasaw Nation Constitution|VI|5", "x": "Within nine (9) months following the first election of officials under this"}, {"t": "6", "p": "
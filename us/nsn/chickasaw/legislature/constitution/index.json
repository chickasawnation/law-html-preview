ion Constitution|VII|6", "x": "The Tribal Legislature shall prescribe election procedures and regulations "}, {"t": "7", "p": "/us/nsn/chickasaw/legislature/constitution#VII/7", "et": "section", "sc": " ARTICLE VII, 7", "rp": "VII|\u00a77", "sp": "library|Chickasaw Nation Constitution|VII|7", "x": "The Tribal Legislature shall make decisions pertaining to the acquisition, "}, {"t": "8", "p": "/us/nsn/chickasaw/legislature/constitution#VII/8", "et": "section", "sc": " ARTICLE VII, 8", "rp": "VII|\u00a78", "sp": "library|Chickasaw Nation Constitution|VII|8", "x": "The Tribal Legislature shall sit as a court in all cases of impeachment; it"}, {"t": "9", "p": "/us/nsn/chickasaw/legislature/constitution#VII/9", "et": "section", "sc": " ARTICLE VII, 9", "rp": "VII|\u00a79", "sp": "library|Chickasaw Nation Constitution|VII|9", "x": "The Governor shall prepare an Annual Tribal Budget and present it to the Le"}, {"t": "10", "p": "/us/nsn/chickasaw/legislature/constitution#VII/10", "et": "section", "sc": " ARTICLE VII, 10", "rp": "VII|\u00a710", "sp": "library|Chickasaw Nation Constitution|VII|10", "x": "For all business of the Legislature, a quorum is required.  A quorum consis"}, {"t": "11", "p": "/us/nsn/chickasaw/legislature/constitution#VII/11", "et": "section", "sc": " ARTICLE VII, 11", "rp": "VII|\u00a711", "sp": "library|Chickasaw Nation Constitution|VII|11", "x": "The Tribal Legislature shall have the power to fix and prescribe salaries a"}, {"t": "12", "p": "/us/nsn/chickasaw/legislature/constitution#VII/12", "et": "section", "sc": " ARTICLE VII, 12", "rp": "VII|\u00a712", "sp": "library|Chickasaw Nation Constitution|VII|12", "x": "The Tribal Legislature shall adopt rules of procedure for operation of the "}]}, {"t": "ARTICLE VIII SESSIONS OF THE TRIBAL LEGISLATURE", "p": "/us/nsn/chickasaw/legislature/constitution#VIII", "et": "container", "sc": " ARTICLE VIII", "rp": "VIII", "sp": "library|Chickasaw Nation Constitution|VIII", "c": [{"t": "1", "p": "/us/nsn/chickasaw/legislature/constitution#VIII/1", "et": "section", "sc": " ARTICLE VIII, 1", "rp": "VIII|\u00a71", "sp": "library|Chickasaw Nation Constitution|VIII|1", "x": "Regular \tsessions \tof \tthe \tTribal"}, {"t": "2", "p": "/us/nsn/chickasaw/legislature/constitution#VIII/2", "et": "section", "sc": " ARTICLE VIII, 2", "rp": "VIII|\u00a72", "sp": "library|Chickasaw Nation Constitution|VIII|2", "x": "Nine (9) members must be present to constitute a quorum."}, {"t": "3", "p": "/us/nsn/chickasaw/legislature/constitution#VIII/3", "et": "section", "sc": " ARTICLE VIII, 3", "rp": "VIII|\u00a73", "sp": "library|Chickasaw Nation Constitution|VIII|3", "x": "The Governor may call a special session of the Legislature at any time he d"}, {"t": "4", "p": "/us/nsn/chickasaw/legislature/constitution#VIII/4", "et": "section", "sc": " ARTICLE VIII, 4", "rp": "VIII|\u00a74", "sp": "library|Chickasaw Nation Constitution|VIII|4", "x": "All regular and special sessions shall be open to the citizens of the Natio"}, {"t": "5", "p": "/us/nsn/chickasaw/legislature/constitution#VIII/5", "et": "section", "sc": " ARTICLE VIII, 5", "rp": "VIII|\u00a75", "sp": "library|Chickasaw Nation Constitution|VIII|5", "x": "Roll call votes shall be recorded, showing how each member of the Tribal Le"}, {"t": "6", "p": "/us/nsn/chickasaw/legislature/constitution#VIII/6", "et": "section", "sc": " ARTICLE VIII, 6", "rp": "VIII|\u00a76", "sp": "library|Chickasaw Nation Constitution|VIII|6", "x": "Robert's Rules of Order shall be followed in conducting Tribal Legislature "}]}, {"t": "ARTICLE IX ORDER OF BUSINESS", "p": "/us/nsn/chickasaw/legislature/constitution#IX", "et": "container", "sc": " ARTICLE IX", "rp": "IX", "sp": "library|Chickasaw Nation Constitution|IX", "c": [{"t": "1.", "p": "/us/nsn/chickasaw/legislature/constitution#IX1.", "et": "para", "sc": " ARTICLE IX.1.", "rp": "IX|1.", "x": "Call to Order"}, {"t": "2.", "p": "/us/nsn/chickasaw/legislature/constitution#IX2.", "et": "para", "sc": " ARTICLE IX.2."